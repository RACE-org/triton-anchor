# Copy this file to /opt/local-ci/config.env on the local server and edit it.

# Gitee CI relay repository. It stores task code on ci/* and results on local-ci-results.
GITEE_REPO_URL="https://gitee.com/likehupochuan/triton-anchor-local-ci-results.git"
GITEE_OWNER="likehupochuan"
GITEE_REPO="triton-anchor-local-ci-results"
GITEE_BRANCH="ci/push/jiwang-delivery-ci"
# GitHub dispatch writes push tasks to ci/push/*, PR head tasks to ci/pr-*,
# and PR base pointers to ci/base/pr-*. The poller intentionally runs only
# push/head tasks; base pointers are consumed only for compile-time baselines.
# Discover all refs in this relay repository, then accept only those task refs.
GITEE_BRANCHES="ci/push/jiwang-delivery-ci"
GITEE_POLL_ALL_BRANCHES="1"
# Applied after branch discovery. The local-ci-results branch is never selected.
GITEE_BRANCH_INCLUDE_REGEX="^ci/(pr-[0-9]+|push/.+)$"

# Optional token used to read the private relay, push results, and create commit comments.
# Keep the real token in config.env or the shell environment, not in git.
GITEE_TOKEN=""
GITEE_USERNAME="likehupochuan"
GITEE_RESULT_CONTEXT="local-ci/sophgo-cmodel"

# Results use a dedicated branch in the same relay repository as the ci/* task refs.
GITEE_RESULTS_OWNER="likehupochuan"
GITEE_RESULTS_REPO="triton-anchor-local-ci-results"
GITEE_RESULTS_REPO_URL="https://gitee.com/likehupochuan/triton-anchor-local-ci-results.git"
GITEE_RESULTS_BRANCH="local-ci-results"
GITEE_RESULTS_WEB_URL="https://gitee.com/likehupochuan/triton-anchor-local-ci-results"
PUBLISH_GITEE_RESULTS="1"
GITEE_WEB_URL="https://gitee.com/likehupochuan/triton-anchor-local-ci-results"

# Host-side runner settings.
LOCAL_CI_CONTAINER="triton-anchor-dev"
LOCAL_CI_STATE_DIR="/root/projects/test/local-ci-state"
LOCAL_CI_SCRIPT_DIR="/opt/local-ci/triton-anchor-runner/scripts/local_ci"
LOCAL_CI_POLL_INTERVAL="60"
LOCAL_CI_WORKSPACE_HOST="/root/projects/test/workspace"

# Container-side prepared workspace. Backend/LLVM/PPL/FlagGems are expected to already exist.
WORKSPACE="/workspace"
ANCHOR_DIR="/workspace/triton-anchor"
LLVM_BUILD_DIR="/workspace/llvm-release"
PPL_ROOT="/workspace/ppl-release"
LOCAL_CI_ARTIFACT_ROOT="/workspace/local-ci-artifacts"

# Backend profile. For another backend, change these paths/commands only.
BACKEND_PROFILE="sophgo-cmodel"
EXPECTED_TRITON_BACKEND="sophgo"
BACKEND_PATH="/workspace/triton-sophgo-backend"
BACKEND_ENVSETUP="envsetup.sh"
BACKEND_ENVSETUP_ARGS="PIO_CMODEL"
BACKEND_TEST_COMMAND="python3 tests/test_smoke.py && python3 tests/test_jit.py"

# By default run only one abs-op smoke. Override FLAGGEMS_TEST_COMMAND to use another script.
RUN_FLAGGEMS_TESTS="true"
FLAGGEMS_CLONE_DIR="/workspace/FlagGems"
FLAGGEMS_REF=""
FLAGGEMS_PIP_PACKAGES="scipy pytest"
FLAGGEMS_TEST_OP="abs"
FLAGGEMS_TEST_COMMAND=""
INSTALL_FLAGGEMS_PACKAGES="1"
#
# Build controls. Leave FRONTEND_BUILD_COMMAND empty to auto-select uv or python -m build.
PACKAGE_TOOL="auto"
PYTHON_BIN="python3"
PYTHON_VENV_ACTIVATE="/opt/venv/bin/activate"
SOURCE_ENVSETUP="1"
FRONTEND_BUILD_COMMAND=""

# Compile-time regression. PR tasks compare these four kernels against the
# cached result for the PR base SHA. A missing baseline is measured once.
RUN_COMPILE_BENCHMARK="true"
COMPILE_BENCHMARK_KERNELS="add,mm,softmax,layernorm"
COMPILE_BENCHMARK_REPEAT="5"
COMPILE_BENCHMARK_WARMUP="1"
COMPILE_BENCHMARK_THRESHOLD="0.20"
COMPILE_BENCHMARK_TIMEOUT="30m"

# Keep source/backend rebuilds within the server's resource limit.
MAX_JOBS="1"
CMAKE_BUILD_PARALLEL_LEVEL="1"
NINJAFLAGS="-j1"
UV_LINK_MODE="copy"
